# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here

# GEMINI SETTINGS
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MAX_RETRIES=2
GEMINI_FALLBACK_MODELS=gemini-1.5-flash,gemini-2.0-flash

# LOCAL LLM SETTINGS (GGUF via llama-cpp)
# Download model from: https://huggingface.co/microsoft/Phi-3-mini-4k-instruct-gguf
LOCAL_MODEL_PATH=./model/Phi-3-mini-4k-instruct-q4.gguf
LOCAL_MAX_TOKENS=512

# LAB CONFIG
# Options: openai | google | gemini | local
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o
AGENT_VERSION=v2
LOG_LEVEL=INFO
